# Motor selection: "pdxc" | "mock" | "auto" (default)
# - pdxc: require real PDXC hardware (fails if not connected)
# - mock: force mock motor regardless of hardware
# - auto: try PDXC first, fall back to mock
MOTOR_TYPE=auto

# Camera selection: "imaging_source" | "mock" | "auto" (default)
# - imaging_source: require real ImagingSource GigE camera (fails if not connected)
# - mock: force mock camera regardless of hardware
# - auto: try ImagingSource first, fall back to mock
CAMERA_TYPE=auto

# Camera settings (required when CAMERA_TYPE=imaging_source or auto)
CAMERA_SERIAL_NUMBER=1234567890
GENTL_CTI_PATH=/path/to/gentl

# Physical pixel scale at the sample plane, in microns per pixel.
# Accounts for any lens, objective, or relay optics in the optical path.
# Leave unset if uncalibrated; the camera will report null for um_per_pixel.
# Example: a 10x objective on a sensor with 3.45 µm pixels → 0.345
#CAMERA_UM_PER_PIXEL=1.0
