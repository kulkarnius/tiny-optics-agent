FROM python:3.11-slim

# libgomp1:    OpenMP runtime required for numba @parallel kernels
# libfftw3-dev: FFTW3 headers + shared libs required by pyfftw
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    libfftw3-dev \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    numpy \
    scipy \
    sympy \
    matplotlib \
    opencv-python-headless \
    numba \
    pandas \
    pyfftw

RUN useradd -m -u 1000 sandbox \
    && mkdir -p /shared \
    && chown sandbox:sandbox /shared

COPY scratchpad/executor.py /app/executor.py
RUN chown sandbox:sandbox /app/executor.py

USER sandbox
WORKDIR /shared

ENV MPLBACKEND=Agg

CMD ["sleep", "infinity"]
