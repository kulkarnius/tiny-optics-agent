# Motor selection: "pdxc" | "mock" | "auto" (default)
# - pdxc: require real PDXC hardware (fails if not connected)
# - mock: force mock motor regardless of hardware
# - auto: try PDXC first, fall back to mock
MOTOR_TYPE=auto

# Camera settings (for ImagingSourceCamera)
CAMERA_SERIAL_NUMBER=1234567890
GENTL_CTI_PATH=/path/to/gentl
